{
  "name": "finalreact",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.4",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.574.0",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.0",
    "react-router-dom": "^7.13.0",
    "react-scripts": "5.0.1",
    "react-scroll-to-top": "^3.1.0",
    "react-type-animation": "^3.2.0",
    "react-use-cart": "^1.14.0",
    "three": "^0.184.0",
    "uuid": "^14.0.0",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:report": "CI=true react-scripts test --reporters=default --reporters=jest-html-reporter",
    "test:coverage": "CI=true react-scripts test --coverage --coverageReporters=text --coverageReporters=html --coverageReporters=lcov",
    "eject": "react-scripts eject"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/**/*.test.{js,jsx}"
    ],
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js",
      "^react-router/internal$": "<rootDir>/node_modules/react-router/dist/development/index.js"
    }
  },
  "jest-html-reporter": {
    "pageTitle": "Packora Frontend Test Report",
    "outputPath": "./test-reports/test-report.html",
    "includeFailureMsg": true,
    "includeConsoleLog": true
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "jest-html-reporter": "^3.10.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2"
  }
}
